{
  "name": "pod blocks missing GitHub auth status",
  "mode": "pod",
  "platform": "linux",
  "unameMachine": "aarch64",
  "env": {
    "WM_ROLE": "mobile-app-dev",
    "WM_EXPECTED_ROLE": "mobile-app-dev"
  },
  "files": {
    "workspaceIdentity": "mobile-app-dev",
    "codexConfigToml": true
  },
  "commands": {
    "nodeVersion": { "status": 0, "stdout": "v22.22.2\n", "stderr": "" },
    "pnpmVersion": { "status": 0, "stdout": "9.15.9\n", "stderr": "" },
    "whichCodex": { "status": 0, "stdout": "/usr/local/bin/codex\n", "stderr": "" },
    "gitUserName": { "status": 0, "stdout": "WonderMove Bot\n", "stderr": "" },
    "gitUserEmail": { "status": 0, "stdout": "wm-bot@example.invalid\n", "stderr": "" },
    "ghAuthStatus": { "status": 1, "stdout": "", "stderr": "not logged in\n" },
    "chromiumPath": { "status": 0, "stdout": "/usr/bin/chromium\n", "stderr": "" },
    "codexMcpList": { "status": 0, "stdout": "mobile-mcp\n", "stderr": "" }
  },
  "candidates": [
    {
      "path": "/usr/local/bin/codex",
      "exists": true,
      "executable": true,
      "fileOutput": "/usr/local/bin/codex: ELF 64-bit LSB executable, ARM aarch64",
      "version": { "status": 0, "stdout": "codex-cli 0.137.0\n", "stderr": "" },
      "execHelp": { "status": 0, "stdout": "Usage: codex exec [OPTIONS]\n", "stderr": "" },
      "smoke": { "status": 0, "stdout": "LOCAL_CODEX_HEADLESS_OK\n", "stderr": "" }
    }
  ],
  "expected": {
    "status": "blocked",
    "blockerReason": "github-auth-unavailable"
  }
}
